{
    "compilerOptions": {
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "noImplicitAny": true,
        "lib": ["ES2024", "ES6", "DOM", "DOM.Iterable"],
        "target": "ES2024",
        "skipLibCheck": true,
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "noEmit": true
    },
    "include": ["client/**/*.ts", "shared/**/*.ts", "components.ts"],
    "exclude": ["node_modules/", "dist/"]
}
