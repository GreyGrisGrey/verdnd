{
    "compilerOptions": {
        "module": "es6",
        "noImplicitAny": true,
        "removeComments": true,
        "preserveConstEnums": true,
        "lib": ["ES2024", "ES6", "DOM", "DOM.Iterable"],
        "target": "ES2024",
        "skipLibCheck": true
    },
    "include": ["clientOut.ts"],
    "exclude": ["node_modules/"],
    "moduleResolution": "nodenext",
    "resolveJsonModule": true
}
