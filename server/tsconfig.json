{
    "compilerOptions": {
        "module": "NodeNext",
        "noImplicitAny": true,
        "removeComments": true,
        "preserveConstEnums": true,
        "lib": ["ES2024", "ES6", "DOM", "DOM.Iterable"],
        "target": "ESNext",
        "types": ["node"],
        "moduleResolution": "NodeNext",
        "paths": {
            "local/*": ["./node_modules/*"]
        },
        "allowJs": true
    },
    "include": ["../serveOut.ts"],
    "exclude": ["../node_modules"],
    "moduleResolution": "NodeNext",
    "resolveJsonModule": true
}
