{
    "compilerOptions": {
        "module": "NodeNext",
        "noImplicitAny": true,
        "lib": ["ES2024"],
        "target": "ES2024",
        "types": ["node"],
        "moduleResolution": "NodeNext",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": ["./**/*.ts", "../shared/**/*.ts"],
    "exclude": ["../node_modules", "../dist"]
}
